# This is a template, not read directly -- copy it OUTSIDE this repo, e.g.:
#
#   mkdir -p ~/.config/decal-scanner
#   cp scripts/env.example ~/.config/decal-scanner/env
#   chmod 600 ~/.config/decal-scanner/env
#   # then fill in JIRA_API_TOKEN and JIRA_EPIC_JQL/JIRA_CHILD_PROJECTS below
#
# sync_jira.py loads that file automatically for manual runs (real exported
# env vars still win), and systemd's EnvironmentFile points at it too. Never
# put the filled-in version inside the git repo.

JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=

# Required -- the in-repo defaults are non-working placeholders on purpose.
# Your real project key, custom field name, and site names are org-internal
# structure, treated like a credential: only ever set here, never committed.
JIRA_EPIC_JQL=project = YOUR_PROJECT AND type = Epic AND "your rover-location field[dropdown]" IN (YOUR_SITE_A, YOUR_SITE_B)
JIRA_CHILD_PROJECTS=YOUR_PROJECT

# Optional overrides.
# JIRA_CHILD_TYPES=Robot Calibration,Oncall - Tier 1,Tech Support Service Request,Task
# JIRA_EPIC_CHUNK_SIZE=150

# Local clone of this repo that the script commits/pushes robots.json into.
# Defaults to the repo this script lives in.
# REPO_DIR=/home/you/decal-scanner

# Set to false to write robots.json locally without committing/pushing
# (useful for a dry run).
# GIT_PUSH=true
